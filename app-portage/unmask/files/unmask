#!/usr/bin/env bash

set -euo pipefail

usage() {
    echo "Usage: unmask <category/package>" >&2
    exit 1
}

if [[ $# -ne 1 ]]; then
    usage
fi

atom=$1

if [[ $atom != */* ]]; then
    echo "Expected a package atom like category/package" >&2
    exit 1
fi

category=${atom%%/*}
config_root=${PORTAGE_CONFIG_ROOT:-/etc/portage}
keywords_path=${config_root}/package.accept_keywords
entry="=${atom} ~amd64"

if [[ -d $keywords_path ]]; then
    target=${keywords_path}/${category}
elif [[ -e $keywords_path ]]; then
    target=$keywords_path
else
    mkdir -p "$keywords_path"
    target=${keywords_path}/${category}
fi

touch "$target"

if grep -Fqx "$entry" "$target"; then
    echo "Already present in $target"
    exit 0
fi

printf '%s\n' "$entry" >> "$target"
echo "Added $entry to $target"