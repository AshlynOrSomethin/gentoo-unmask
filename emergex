#!/usr/bin/env bash

set -euo pipefail

usage() {
    echo "Usage: emergex <emerge arguments...>" >&2
    exit 1
}

if [[ $# -lt 1 ]]; then
    usage
fi

emerge_bin=${EMERGEX_EMERGE_BIN:-emerge}
etc_update_bin=${EMERGEX_ETC_UPDATE_BIN:-etc-update}
root_helper=${EMERGEX_ROOT_HELPER:-sudo}

run_as_root() {
    if [[ ${EUID} -eq 0 ]]; then
        "$@"
    else
        "$root_helper" "$@"
    fi
}

run_as_root "$emerge_bin" --autounmask-write --autounmask-continue "$@"

if [[ ${EMERGEX_SKIP_ETC_UPDATE:-0} != 1 ]]; then
    run_as_root "$etc_update_bin" --automode -5
fi